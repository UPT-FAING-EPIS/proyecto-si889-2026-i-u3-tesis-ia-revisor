# Recomendado en local: llamar directo a FastAPI para evitar timeouts del proxy
# de Next.js con respuestas largas de modelos como DeepSeek.
NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:8000

# URL interna que usa Next.js si decides mantener el proxy /backend.
BACKEND_INTERNAL_URL=http://127.0.0.1:8000
